# =============================================================================
# Trinity AI Labs — Environment Variables
# Copy this to .env.local and fill in the values
# =============================================================================

# App
BETTER_AUTH_URL=http://localhost:3100

# Admin
ADMIN_EMAILS=your@email.com

# Turso (database)
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=
TURSO_ORG=trinity-ai-labs
TURSO_PLATFORM_API_TOKEN=

# OAuth — Google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# OAuth — GitHub
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Device auth (JWT signing)
JWT_SECRET=

# Lemon Squeezy (billing)
LEMONSQUEEZY_API_KEY=
LEMONSQUEEZY_STORE_ID=
LEMONSQUEEZY_VARIANT_ID=
LEMONSQUEEZY_STORAGE_ADDON_VARIANT_ID=
LEMONSQUEEZY_WEBHOOK_SECRET=

# Resend (email)
RESEND_API_KEY=

# Cloudflare R2 (asset storage)
R2_ENDPOINT=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=trinity-assets

# GitHub (dev activity stats on landing page)
GITHUB_TOKEN=

# Upstash Redis (rate limiting) — optional, skipped if not set
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
